{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "rew",
  "version": "0.1.0",
  "identifier": "com.rew.app",
  "build": {
    "frontendDist": "../gui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd gui && pnpm dev",
    "beforeBuildCommand": "if [ \"$CI\" = 'true' ]; then cd gui && pnpm build; else ./scripts/test-all.sh && cargo build --release -p rew-cli && cp \"${CARGO_TARGET_DIR:-target}/release/rew\" src-tauri/rew && cd gui && pnpm build; fi"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1300,
        "height": 840,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "decorations": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "rew"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: xu zhang (TV3TFAJ56J)",
      "providerShortName": "TV3TFAJ56J",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.github.com/repos/kuqili/rew/releases/latest"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2RjJFMkY5MUI0MkM5QjgKUldTNHlVSWIrZUx5Rmx3b0RZR0tsSmtkdGEzdngvQjdyRXNvWFRkbVFaNndaSllnY0ZoUmFISG4K"
    }
  }
}
