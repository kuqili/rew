{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "rew",
  "version": "0.1.0",
  "identifier": "com.rew.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "rew — AI 时代的文件安全网",
        "width": 1000,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "decorations": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "rew-tray",
      "iconPath": "icons/tray-normal.png",
      "iconAsTemplate": true,
      "tooltip": "rew — 文件保护运行中"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
